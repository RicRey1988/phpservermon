<?xml version="1.0" encoding="UTF-8" ?>

<container xmlns="http://symfony.com/schema/dic/services"
xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">
	<parameters>
		<parameter key="config.theme" type="constant">PSM_THEME</parameter>

		<parameter key="modules" type="collection">
			<parameter>module.config</parameter>
			<parameter>module.error</parameter>
			<parameter>module.server</parameter>
			<parameter>module.user</parameter>
			<parameter>module.install</parameter>
		</parameter>

		<parameter key="path.src" type="constant">PSM_PATH_SRC</parameter>
		<parameter key="path.root">%path.src%..</parameter>
		<parameter key="path.logs" type="constant">PSM_PATH_LOGS</parameter>
		<parameter key="path.templates">%path.src%templates</parameter>
		<parameter key="path.server_images">%path.src%../public/server-images</parameter>
		<parameter key="url.server_images">public/server-images</parameter>
		<parameter key="url.server_image_generic">src/templates/default/static/images/server-generic.svg</parameter>
		<parameter key="path.user_media">%path.src%../public/user-media</parameter>
		<parameter key="url.user_media">public/user-media</parameter>

		<parameter key="db.host" type="constant">PSM_DB_HOST</parameter>
		<parameter key="db.port" type="constant">PSM_DB_PORT</parameter>
		<parameter key="db.user" type="constant">PSM_DB_USER</parameter>
		<parameter key="db.pass" type="constant">PSM_DB_PASS</parameter>
		<parameter key="db.name" type="constant">PSM_DB_NAME</parameter>
	</parameters>

	<services>
		<!--MODULES start-->
		<service id="module.config" class="psm\Module\Config\ConfigModule" />
		<service id="module.error" class="psm\Module\Error\ErrorModule" />
		<service id="module.server" class="psm\Module\Server\ServerModule" />
		<service id="module.user" class="psm\Module\User\UserModule" />
		<service id="module.install" class="psm\Module\Install\InstallModule" />
		<!--MODULES end-->

		<!--SERVICES start-->
		<service id="db" class="psm\Service\Database">
			<argument>%db.host%</argument>
			<argument>%db.user%</argument>
			<argument>%db.pass%</argument>
			<argument>%db.name%</argument>
			<argument>%db.port%</argument>
		</service>

		<service id="event" class="Symfony\Component\EventDispatcher\EventDispatcher">
			<argument type="service" id="service_container" />
		</service>
		<service id="user" class="psm\Service\User">
			<argument type="service" id="db" />
		</service>
		<service id="twig.loader" class="Twig\Loader\FilesystemLoader">
			<argument>%path.templates%/%config.theme%</argument>
		</service>
		<service id="twig" class="Twig\Environment">
			<argument type="service" id="twig.loader" />
		</service>
		<service id="service.push.subscription_repository" class="psm\Service\Push\PushSubscriptionRepository" public="true">
			<argument type="service" id="db" />
		</service>
		<service id="service.invitation.repository" class="psm\Service\Invitation\InvitationRepository" public="true">
			<argument type="service" id="db" />
		</service>
		<service id="service.system.health" class="psm\Service\System\SystemHealthService" public="true">
			<argument>%path.root%</argument>
			<argument>%path.logs%</argument>
			<argument type="service" id="db" />
		</service>
		<service id="service.system.job_runs" class="psm\Service\System\JobRunRepository" public="true">
			<argument type="service" id="db" />
		</service>
		<service id="service.system.release_client" class="psm\Service\SystemUpdate\GitHubReleaseClient" public="true" />
		<service id="service.system.package_verifier" class="psm\Service\SystemUpdate\ReleasePackageVerifier" />
		<service id="service.system.manifest_verifier" class="psm\Service\Update\ManifestVerifier" />
		<service id="service.system.release_installer" class="psm\Service\SystemUpdate\ReleaseInstaller">
			<argument>%path.root%</argument>
			<argument>%path.logs%</argument>
		</service>
		<service id="service.system.maintenance" class="psm\Service\SystemUpdate\MaintenanceMode">
			<argument>%path.root%</argument>
		</service>
		<service id="service.system.updater" class="psm\Service\SystemUpdate\SystemUpdater" public="true">
			<argument type="service" id="service.system.release_client" />
			<argument type="service" id="service.system.package_verifier" />
			<argument type="service" id="service.system.manifest_verifier" />
			<argument type="service" id="service.system.release_installer" />
			<argument type="service" id="service.system.maintenance" />
			<argument>%path.root%</argument>
			<argument type="service" id="service.system.job_runs" />
		</service>
		<service id="notification.registry" class="psm\Notification\ChannelRegistry" public="true">
			<factory class="psm\Notification\ChannelRegistryFactory" method="create" />
			<argument type="service" id="service.push.subscription_repository" />
		</service>
		<service id="service.platform_requirements" class="psm\Util\Install\PlatformRequirements" />
		<service id="service.php_info" class="psm\Service\PhpInfoService" public="true">
			<argument type="service" id="service.platform_requirements" />
		</service>
		<service id="service.ui.appearance" class="psm\Service\Ui\AppearanceService" public="true">
			<argument type="service" id="user" />
		</service>
		<service id="service.server_image.processor" class="psm\Service\ServerImage\GdImageProcessor" public="true" />
		<service id="service.server_image.storage" class="psm\Service\ServerImage\ServerImageStorage" public="true">
			<argument>%path.server_images%</argument>
			<argument>%url.server_images%</argument>
			<argument>%url.server_image_generic%</argument>
		</service>
		<service id="service.server_image.manager" class="psm\Service\ServerImage\ServerImageManager" public="true">
			<argument type="service" id="db" />
			<argument type="service" id="service.server_image.processor" />
			<argument type="service" id="service.server_image.storage" />
		</service>
		<service id="service.user_media.storage" class="psm\Service\UserMedia\UserMediaStorage" public="true">
			<argument>%path.user_media%</argument>
			<argument>%url.user_media%</argument>
		</service>
		<service id="service.user_media.manager" class="psm\Service\UserMedia\IdentityImageManager" public="true">
			<argument type="service" id="service.server_image.processor" />
			<argument type="service" id="service.user_media.storage" />
		</service>
		<service id="service.dashboard_statistics" class="psm\Service\Statistics\DashboardStatistics" public="true">
			<argument type="service" id="db" />
		</service>
		<service id="service.incident.repository" class="psm\Service\Incident\IncidentRepository">
			<argument type="service" id="db" />
		</service>
		<service id="service.incident.manager" class="psm\Service\Incident\IncidentManager" public="true">
			<argument type="service" id="service.incident.repository" />
		</service>
		<service id="service.notification.delivery_repository" class="psm\Service\Notification\DeliveryRepository">
			<argument type="service" id="db" />
		</service>
		<service id="service.notification.recipient_repository" class="psm\Service\Notification\IncidentRecipientRepository">
			<argument type="service" id="db" />
		</service>
		<service id="service.notification.incident_composer" class="psm\Service\Notification\IncidentMessageComposer">
			<argument type="service" id="db" />
		</service>
		<service id="service.notification.incident_dispatcher" class="psm\Service\Notification\IncidentNotificationDispatcher" public="true">
			<argument type="service" id="service.notification.delivery_repository" />
			<argument type="service" id="service.notification.recipient_repository" />
			<argument type="service" id="service.notification.incident_composer" />
			<argument type="service" id="notification.registry" />
		</service>
		<service id="service.notification.user_repository" class="psm\Service\Notification\UserNotificationRepository" public="true">
			<argument type="service" id="db" />
		</service>
		<!--SERVICES end-->

		<!--UTIL start-->
		<service id="util.user.validator" class="psm\Util\User\UserValidator">
			<argument type="service" id="user" />
		</service>
		<service id="util.server.updatemanager" class="psm\Util\Server\UpdateManager">
			<argument type="service" id="service_container" />
		</service>
		<!--UTIL end-->
	</services>
</container>
